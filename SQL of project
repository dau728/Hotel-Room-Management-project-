-- ============================================================
-- HOTEL ROOM MANAGEMENT SYSTEM (MySQL / phpMyAdmin version)
-- Tables: Room, Guest, Employee, Booking, Payment
-- Includes Primary/Foreign Keys, Views, Data Masking,
-- and Room Availability Status
-- ============================================================

-- Run this first if you got "table already exists" errors.
-- It safely removes any old copies before recreating them.
DROP VIEW IF EXISTS Guest_Masked_View;
DROP VIEW IF EXISTS Employee_Masked_View;
DROP VIEW IF EXISTS Payment_Summary_View;
DROP VIEW IF EXISTS Room_Status_Summary_View;
DROP VIEW IF EXISTS Available_Rooms_View;
DROP VIEW IF EXISTS Booking_Details_View;
DROP TABLE IF EXISTS Payment;
DROP TABLE IF EXISTS Booking;
DROP TABLE IF EXISTS Employee;
DROP TABLE IF EXISTS Guest;
DROP TABLE IF EXISTS Room;

-- 1. TABLE: Room (parent table - PK = room_id)
CREATE TABLE Room (
    room_id      INT AUTO_INCREMENT PRIMARY KEY,
    room_number  VARCHAR(10) NOT NULL UNIQUE,
    room_type    VARCHAR(20) NOT NULL,
    price_per_night DECIMAL(10,2) NOT NULL,
    status       ENUM('Available', 'Occupied', 'Maintenance', 'Reserved')
                 NOT NULL DEFAULT 'Available'
);

-- 2. TABLE: Guest (parent table - PK = guest_id)
CREATE TABLE Guest (
    guest_id     INT AUTO_INCREMENT PRIMARY KEY,
    guest_name   VARCHAR(100) NOT NULL,
    cnic         VARCHAR(20) NOT NULL,
    phone        VARCHAR(20) NOT NULL,
    email        VARCHAR(100) NOT NULL
);

-- 3. TABLE: Employee (parent table - PK = emp_id)
CREATE TABLE Employee (
    emp_id       INT AUTO_INCREMENT PRIMARY KEY,
    emp_name     VARCHAR(100) NOT NULL,
    designation  VARCHAR(50) NOT NULL,
    cnic         VARCHAR(20) NOT NULL,
    phone        VARCHAR(20) NOT NULL,
    salary       DECIMAL(10,2) NOT NULL
);

-- 4. TABLE: Booking (child table - FKs to Guest, Room, Employee)
CREATE TABLE Booking (
    booking_id   INT AUTO_INCREMENT PRIMARY KEY,
    guest_id     INT NOT NULL,
    room_id      INT NOT NULL,
    emp_id       INT,
    check_in     DATE NOT NULL,
    check_out    DATE NOT NULL,
    total_amount DECIMAL(10,2) NOT NULL,
    FOREIGN KEY (guest_id) REFERENCES Guest(guest_id),
    FOREIGN KEY (room_id)  REFERENCES Room(room_id),
    FOREIGN KEY (emp_id)   REFERENCES Employee(emp_id)
);

-- 5. TABLE: Payment (child table - FK to Booking)
CREATE TABLE Payment (
    payment_id     INT AUTO_INCREMENT PRIMARY KEY,
    booking_id     INT NOT NULL,
    amount_paid    DECIMAL(10,2) NOT NULL,
    payment_date   DATE NOT NULL,
    payment_method ENUM('Cash', 'Credit Card', 'Debit Card', 'Online Transfer') NOT NULL,
    payment_status ENUM('Pending', 'Paid', 'Refunded') NOT NULL DEFAULT 'Pending',
    FOREIGN KEY (booking_id) REFERENCES Booking(booking_id)
);

