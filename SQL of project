-- VIEW 1: Booking Details View
CREATE VIEW Booking_Details_View AS
SELECT
    b.booking_id,
    g.guest_name,
    r.room_number,
    r.room_type,
    e.emp_name   AS handled_by,
    b.check_in,
    b.check_out,
    b.total_amount
FROM Booking b
JOIN Guest g    ON b.guest_id = g.guest_id
JOIN Room  r    ON b.room_id  = r.room_id
LEFT JOIN Employee e ON b.emp_id = e.emp_id;

-- VIEW 2: Available Rooms View
CREATE VIEW Available_Rooms_View AS
SELECT room_id, room_number, room_type, price_per_night, status
FROM Room
WHERE status = 'Available';

-- VIEW 3: Room Status Summary View (dashboard)
CREATE VIEW Room_Status_Summary_View AS
SELECT status, COUNT(*) AS total_rooms
FROM Room
GROUP BY status;

-- VIEW 4: Payment Summary View
CREATE VIEW Payment_Summary_View AS
SELECT
    p.payment_id,
    g.guest_name,
    r.room_number,
    p.amount_paid,
    p.payment_date,
    p.payment_method,
    p.payment_status
FROM Payment p
JOIN Booking b ON p.booking_id = b.booking_id
JOIN Guest g   ON b.guest_id   = g.guest_id
JOIN Room r    ON b.room_id    = r.room_id;

-- VIEW 5: Guest_Masked_View (hides CNIC, phone, email)
CREATE VIEW Guest_Masked_View AS
SELECT
    guest_id,
    guest_name,
    CONCAT(LEFT(cnic, 6), 'XXXXXXX-X') AS cnic_masked,
    CONCAT('XXXX-XXX', RIGHT(phone, 4)) AS phone_masked,
    CONCAT(LEFT(email, 2), '****@', SUBSTRING_INDEX(email, '@', -1)) AS email_masked
FROM Guest;

-- VIEW 6: Employee_Masked_View (hides CNIC, phone, salary)
CREATE VIEW Employee_Masked_View AS
SELECT
    emp_id,
    emp_name,
    designation,
    CONCAT(LEFT(cnic, 6), 'XXXXXXX-X') AS cnic_masked,
    CONCAT('XXXX-XXX', RIGHT(phone, 4)) AS phone_masked,
    'CONFIDENTIAL' AS salary
FROM Employee;

-- BONUS: Trigger to auto-update Room status when a booking is made
DROP TRIGGER IF EXISTS trg_room_occupied;

DELIMITER $$
CREATE TRIGGER trg_room_occupied
AFTER INSERT ON Booking
FOR EACH ROW
BEGIN
    UPDATE Room SET status = 'Occupied' WHERE room_id = NEW.room_id;
END$$
DELIMITER ;
